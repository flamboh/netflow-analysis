#!/usr/bin/env sh
set -e

STAGED=$(git diff --cached --name-only --diff-filter=ACMR)

[ -z "$STAGED" ] && exit 0

printf '%s\n' "$STAGED" | tr '\n' '\0' | xargs -0 bunx prettier --write --ignore-unknown

WEB_LINT_TARGETS=$(
	printf '%s\n' "$STAGED" | grep -E '^apps/web/.*\.(cjs|cts|js|jsx|mjs|mts|svelte|ts|tsx)$' | sed 's|^apps/web/||' || true
)

if [ -n "$WEB_LINT_TARGETS" ]; then
	printf '%s\n' "$WEB_LINT_TARGETS" | tr '\n' '\0' | (cd apps/web && xargs -0 bunx eslint --no-warn-ignored)
fi

git update-index --again

bun run typecheck
