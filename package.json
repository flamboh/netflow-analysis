{
  "name": "netflow-analysis",
  "private": true,
  "packageManager": "bun@1.2.16",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:web": "cd apps/web && bun run dev",
    "build:web": "cd apps/web && bun run build",
    "check:web": "cd apps/web && bun run check",
    "lint:web": "cd apps/web && bun run lint",
    "format:web": "cd apps/web && bun run format",
    "format:check:web": "cd apps/web && bun run format:check",
    "test:web": "cd apps/web && bun run test",
    "test:e2e": "cd apps/web && bun run test:e2e",
    "test:e2e:headed": "cd apps/web && bun run test:e2e:headed",
    "precommit:web": "bun run format:web && bun run lint:web && bun run check:web && bun run test:web",
    "precommit:db": "nix-shell --run 'uv run pytest tests/python && python -m compileall tools/netflow-db'",
    "precommit": "bun run precommit:web && bun run precommit:db",
    "check:db": "python -m compileall tools/netflow-db",
    "test": "vitest"
  },
  "devDependencies": {
    "vitest": "^4.1.1"
  }
}
