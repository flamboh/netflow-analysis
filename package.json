{
  "name": "netflow-analysis",
  "private": true,
  "packageManager": "bun@1.2.16",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:web": "cd apps/web && bun run dev",
    "build:web": "cd apps/web && bun run build",
    "check:web": "cd apps/web && bun run check",
    "lint:web": "cd apps/web && bun run lint",
    "format:web": "cd apps/web && bun run format",
    "test:web": "cd apps/web && bun run test",
    "validate:web": "cd apps/web && bun run validate",
    "check:db": "cd tools/netflow-db && python -m py_compile *.py",
    "validate": "bun run validate:web && bun run check:db"
  }
}
