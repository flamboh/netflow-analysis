# NetFlow runtime configuration template
# Copy this file to .env and update with your actual values.
#
# Dataset definitions live in datasets.json. That file controls:
# - dataset ids and labels
# - source data roots
# - per-dataset SQLite output paths
# - discovery mode/source mode

# Default dataset to use when the CLI or web app does not specify one
DEFAULT_DATASET=uoregon

# Optional override for the dataset registry location
# DATASETS_CONFIG_PATH=./datasets.json

# Logs used by the backend pipeline and web log endpoints
LOG_PATH=tools/netflow-db/logs

# Processing configuration
MAX_WORKERS=8
BATCH_SIZE=50

# Set to True to drop and recreate stats tables on first run only
FIRST_RUN=False

# Tool paths
# Leave these unset to use the repo-local defaults under vendor/ after
# `git submodule update --init --recursive`.
# STRUCTURE_FUNCTION_BIN=/absolute/path/to/StructureFunction
# SPECTRUM_BIN=/absolute/path/to/Spectrum
